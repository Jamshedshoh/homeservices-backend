# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Database Configuration
DB_USER=homeservices
DB_PASSWORD=password
DB_NAME=homeservices
DB_PORT=5432

# API Configuration
API_PORT=5001

# PostgreSQL connection string (used by config.py)
# In Docker: postgresql://homeservices:password@db:5432/homeservices
DATABASE_URL=postgresql://user@localhost:5432/homeservices

# JWT
SECRET_KEY=replace-with-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: bootstrap admin user on startup (leave blank to skip)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
